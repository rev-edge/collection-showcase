# Card Vault V0 — environment variables
#
# Week 1 (/demo): no env required.
# Week 2 (/new + /s/[token]): Supabase + Upstash needed.
#
# Copy to .env.local for local development. Mirror in Vercel project settings for prod.

# Supabase — read/write via service role on the server only. No anon key in V0.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — sliding-window rate limit for the create endpoint.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public site URL — used for absolute share links and OG metadata.
# Set this in Netlify (Site settings → Environment variables) to the production URL
# so OG images resolve to https://ultimateshowcase.netlify.app/... and not localhost.
NEXT_PUBLIC_SITE_URL=https://ultimateshowcase.netlify.app
